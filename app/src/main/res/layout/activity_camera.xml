<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000"
    android:paddingVertical="50dp"
    tools:context=".camera.CameraActivity">
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <ImageButton
        android:id="@+id/buttonSwitch"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:src="@drawable/baseline_cameraswitch_24"
        app:tint="@android:color/white"
        android:contentDescription="Switch Camera"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp"/>

    <!-- Flash Button -->
    <ImageButton
        android:id="@+id/buttonFlash"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:src="@drawable/flash_off"
        app:tint="@android:color/white"
        android:contentDescription="Flash"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/buttonSwitch"
        android:layout_margin="16dp"/>


    <!-- Capture Button -->
    <ImageButton
        android:id="@+id/buttonCapture"
        android:layout_width="72dp"
        android:layout_height="72dp"
        app:srcCompat="@drawable/capture_btn"
        android:padding="12dp"
        android:background="@drawable/white_oval_solid_bg"
        android:contentDescription="Capture"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"/>
    <ImageView
        android:id="@+id/album_btn"
        android:layout_width="65dp"
        android:layout_height="72dp"
        android:src="@drawable/baseline_photo_album_24"
       android:layout_marginBottom="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>